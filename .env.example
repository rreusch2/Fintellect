# .env.example
# ... (other keys)

# Environment Configuration
NODE_ENV=development

# Session Secret
SESSION_SECRET=your-secret-key-here

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/fintellect
DIRECT_URL=postgresql://username:password@localhost:5432/fintellect

# Plaid Configuration
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# OpenManus Service
OPENMANUS_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620

# Stripe Configuration (Test Mode)
STRIPE_TEST_KEY=your_stripe_test_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- AI Providers ---
GEMINI_API_KEY=your_gemini_api_key
# E2B Key removed as it's no longer used by Sentinel
# E2B_API_KEY=your_e2b_api_key

# ... (rest of the file)

# --- Sentinel Agent Configuration ---
# USE_OPENMANUS removed as OpenManus is now the only option
# USE_OPENMANUS=false
OPENMANUS_URL=http://localhost:8000

# ... (rest of the file) 